# --------------------------------------------------------------
# 1️⃣ 基础镜像（Alpine + Python 3.11）
# --------------------------------------------------------------
FROM python:3.11-alpine

# --------------------------------------------------------------
# 2️⃣ 系统依赖（仅 tzdata，其他均已在 Python 包中解决）
# --------------------------------------------------------------
RUN apk add --no-cache tzdata

# --------------------------------------------------------------
# 3️⃣ 时区（默认使用 .env 中的 TZ，若未设置则亚洲上海）
# --------------------------------------------------------------
ARG TZ=Asia/Shanghai
ENV TZ=${TZ}
RUN cp /usr/share/zoneinfo/${TZ} /etc/localtime && \
    echo "${TZ}" > /etc/timezone

# --------------------------------------------------------------
# 4️⃣ 防止日志被缓冲
# --------------------------------------------------------------
ENV PYTHONUNBUFFERED=1

# --------------------------------------------------------------
# 5️⃣ 工作目录 & 拷贝代码
# --------------------------------------------------------------
WORKDIR /app

# 先复制依赖文件，利用 Docker 缓存层
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# 再复制所有业务源码（根目录下的 *.py 文件和配置文件）
COPY *.py ./
COPY webhook_config.txt ./
COPY .env.example .env          # 仅作模板，实际运行时请挂载真实 .env

# --------------------------------------------------------------
# 6️⃣ 暴露端口（本项目不提供 Service，留空）
# --------------------------------------------------------------
# EXPOSE 8080   # 如后期要加 Web UI，可取消注释

# --------------------------------------------------------------
# 7️⃣ 启动命令
# --------------------------------------------------------------
CMD python main.py > /app/bili_monitor.log 2>&1
