# --------------------------------------------------------------
# ① 选用轻量的 Python 3.11 + Alpine 镜像
# --------------------------------------------------------------
FROM python:3.11-alpine

# --------------------------------------------------------------
# ② 安装系统依赖（编译 Pillow 必要的 libjpeg、zlib）
# --------------------------------------------------------------
RUN apk add --no-cache \
        tzdata \
        build-base \
        jpeg-dev \
        zlib-dev \
        git \
        bash

# --------------------------------------------------------------
# ③ 设置时区（容器启动时可被环境变量 TZ 覆盖）
# --------------------------------------------------------------
ENV TZ=Asia/Shanghai
RUN cp /usr/share/zoneinfo/${TZ} /etc/localtime && \
    echo "${TZ}" > /etc/timezone

# --------------------------------------------------------------
# ④ 防止 Python 输出被缓存，日志可以实时看到
# --------------------------------------------------------------
ENV PYTHONUNBUFFERED=1

# --------------------------------------------------------------
# ⑤ 工作目录 & 复制源码
# --------------------------------------------------------------
WORKDIR /app

# 先复制依赖文件，利用 Docker 缓存层加速后续构建
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# 复制业务代码（src 目录），保持结构一致
COPY src/ ./src/
COPY webhook_config.txt ./
COPY .env.example .env          # 仅作模板，实际运行时会挂载真实 .env

# --------------------------------------------------------------
# ⑥ 声明容器暴露的端口（本项目不提供 HTTP 服务，留空）
# --------------------------------------------------------------
# EXPOSE 8080   # 如以后改成 Web UI，可取消注释

# --------------------------------------------------------------
# ⑦ 入口命令（每次容器启动都会尝试安装最新依赖，然后运行主程序）
# --------------------------------------------------------------
CMD pip install --no-cache-dir -r requirements.txt && \
    python src/main.py > /app/bili_monitor.log 2>&1
